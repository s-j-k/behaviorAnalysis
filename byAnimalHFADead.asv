sigstar({[1,2]}, p)
dprimeVals = [dp_r_An(1) dp_opto_An(1) dp_r_An(2) dp_opto_An(2) dp_r_An(3) dp_opto_An(3)];
dprimeVals=dprimeVals(~isnan(dprimeVals));
line([1 2],dprimeVals(1:2), 'LineWidth', 0.5, 'Color', [0 0 0]);
