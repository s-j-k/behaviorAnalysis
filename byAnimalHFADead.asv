ohittemp(ohittemp==1)=1-1./(2*140);
ofatemp(ofatemp==1)=1-1./(2*140);
[dp_r,c_r]=dprime_simple(rhittemp,rfatemp);
[dp_opto,c_opto]=dprime_simple(ohittemp, ofatemp);
dp_r(isnan(dp_opto))=nan;
subplot(2, 3, 4); 
dp_re=nansem(dp_r');
dp_rm=nanmean(dp_r');
hold on;
odp_re=nansem(dp_opto');
odp_rm=nanmean(dp_opto');
dp_opto_An=nanmean(dp_opto);
dp_r_An=nanmean(dp_r);
ddd=bar([nanmean(dp_rm) nanmean(odp_rm)]); hold on;
ddd(1).FaceColor='flat';ddd(1).CData=[reinfcolor;optocolor];hold on;
scatter(repmat(ddd(1).XEndPoints(1),size(nanmean(dp_r),2),1), ...
    nanmean(dp_r),'MarkerEdgeColor',[0 0 0],'MarkerFaceColor',reinfcolor);
scatter(repmat(ddd(1).XEndPoints(2),size(nanmean(dp_opto),2),1), ...
    nanmean(dp_opto),'MarkerEdgeColor',[0 0 0],'MarkerFaceColor',optocolor);
[h,p,ci,stats] = ttest2(nanmean(dp_r),nanmean(dp_opto));
sigstar({[1,2]}, p)
dprimeVals = [dp_r_An(1) dp_opto_An(1) dp_r_An(2) dp_opto_An(2) dp_r_An(3) dp_opto_An(3)];
dprimeVals=dprimeVals(~isnan(dprimeVals));
line([1 2],dprimeVals(1:2), 'LineWidth', 0.5, 'Color', [0 0 0]);
line([1 2],dprimeVals(3:4), 'LineWidth', 0.5, 'Color', [0 0 0]);
line([1 2],dprimeVals(5:6), 'LineWidth', 0.5, 'Color', [0 0 0]);
allDataTestsOnly{2,46}=p;
allDataTestsOnly{2,45} = [dp_r_An; dp_opto_An];
allDataTestsOnly{1,45}='dprime delay 4 off,on';allDataTestsOnly{1,46}='p value dprime delay 4';
allDataTestsOnly{3,45}='hit rate delay 4 off,on';allDataTestsOnly{3,46}='fa rate delay 4';
allDataTestsOnly{4,45}=[rhittemp;ohittemp];allDataTestsOnly{4,46}=[rfatemp; ofatemp];
box off
title('Delay 4');ylim([-1 4]);
xticklabels({'','light off','light on'});

clear rhit ohit rfa ofa ohittemp rhittemp fahittemp ofatemp
rhit=0;ohit=0;rfa=0;ofa=0;
for jj=1:length(firstIdxAnimal)
    rhittemp(:,jj)=cell2mat(allDataTestsOnly{firstIdxAnimal(jj),16});
    rfatemp(:,jj)=cell2mat(allDataTestsOnly{firstIdxAnimal(jj),17});
    ohittemp(:,jj)=cell2mat(allDataTestsOnly{firstIdxAnimal(jj),26});
    ofatemp(:,jj)=cell2mat(allDataTestsOnly{firstIdxAnimal(jj),27});
    rhittemp(isnan(ohit))=nan;
    rfatemp(isnan(ofa))=nan;
    rhit(jj)=nanmean(rhittemp(:,jj));
    rfa(jj)=nanmean(rfatemp(:,jj));
    ohit(jj)=nanmean(ohittemp(:,jj));
    ofa(jj) = nanmean(ofatemp(:,jj));
end
rhittemp(rhittemp==1)=1-1./(2*140);
rfatemp(rfatemp==1)=1-1./(2*140);
ohittemp(ohittemp==1)=1-1./(2*140);
ofatemp(ofatemp==1)=1-1./(2*140);
[dp_r,c_r]=dprime_simple(rhittemp,rfatemp);
[dp_opto,c_opto]=dprime_simple(ohittemp, ofatemp);
dp_r(isnan(dp_opto))=nan;
subplot(2,3,5); 
dp_re=nansem(dp_r');
dp_rm=nanmean(dp_r');
hold on;
odp_re=nansem(dp_opto');
odp_rm=nanmean(dp_opto');
dp_opto_An=nanmean(dp_opto);
dp_r_An=nanmean(dp_r);
ddd=bar([nanmean(dp_rm) nanmean(odp_rm)]); hold on;
ddd(1).FaceColor='flat';ddd(1).CData=[reinfcolor;optocolor];hold on;
scatter(repmat(ddd(1).XEndPoints(1),size(nanmean(dp_r),2),1), ...
    nanmean(dp_r),'MarkerEdgeColor',[0 0 0],'MarkerFaceColor',reinfcolor);
scatter(repmat(ddd(1).XEndPoints(2),size(nanmean(dp_opto),2),1), ...
    nanmean(dp_opto),'MarkerEdgeColor',[0 0 0],'MarkerFaceColor',optocolor);
[h,p,ci,stats] = ttest2(nanmean(dp_r),nanmean(dp_opto));
sigstar({[1,2]}, p)
dprimeVals = [dp_r_An(1) dp_opto_An(1) dp_r_An(2) dp_opto_An(2) dp_r_An(3) dp_opto_An(3)];
dprimeVals=dprimeVals(~isnan(dprimeVals));
line([1 2],dprimeVals(1:2), 'LineWidth', 0.5, 'Color', [0 0 0]);
line([1 2],dprimeVals(3:4), 'LineWidth', 0.5, 'Color', [0 0 0]);
line([1 2],dprimeVals(5:6), 'LineWidth', 0.5, 'Color', [0 0 0]);
allDataTestsOnly{2,48}=p;
allDataTestsOnly{2,47} = [dp_r_An; dp_opto_An];
allDataTestsOnly{1,47}='dprime delay 5 off,on';allDataTestsOnly{1,48}='p value dprime delay 5';
allDataTestsOnly{3,47}='hit rate delay 5 off,on';allDataTestsOnly{3,48}='fa rate delay 5';
allDataTestsOnly{4,47}=[rhittemp;ohittemp];allDataTestsOnly{4,48}=[rfatemp;ofatemp];


box off
title('Delay 5');ylim([-1 4]);
xticklabels({'','light off','light on'});


dprimeFig.Position(3:4)=[725 350];
saveas(gcf,['By Animal_T_MGB_dp_bar_Delay_Opto']);
saveas(gcf,['By Animal_T_MGB_dp_bar_Delay_Opto.png']);
saveas(gcf,['By Animal_T_MGB_dp_bar_Delay_Opto.pdf']);

end