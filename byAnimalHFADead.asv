for jj=1:length(firstIdxAnimal)
    rhittemp=cell2mat(allDataTestsOnly{firstIdxAnimal(jj),16}); % dead 5
    rfatemp=cell2mat(allDataTestsOnly{firstIdxAnimal(jj),17});
    ohittemp=cell2mat(allDataTestsOnly{firstIdxAnimal(jj),26});
