rhit=0;ohit=0;rfa=0;ofa=0;
for jj=1:length(firstIdxAnimal)
    rhittemp(:,jj)=cell2mat(allDataTestsOnly{firstIdxAnimal(jj),16});
    rfatemp(:,jj)=cell2mat(allDataTestsOnly{firstIdxAnimal(jj),17});
    ohittemp(:,jj)=cell2mat(allDataTestsOnly{firstIdxAnimal(jj),24});
