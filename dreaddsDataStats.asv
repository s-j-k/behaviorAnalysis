        saveas(gcf,[char(allDataTestsOnly{jj,1}) '_T_MGB_HitFARate_Opto.png']);


        figure(jj+8);
        rhit=allDataTestsOnly{jj,10}; % full trial MGB
        rfa=allDataTestsOnly{jj,11};
