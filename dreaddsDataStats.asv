%% dreadds stats analysis
% now load the data for one cohort
clear all
datapath='O:\sjk\Behavior\cohort_8';
cd(datapath)
load('summaryData.mat');
SESS = 1; CTXT = 2; TONE = 3; OUTCOME = 4; 
START = 5; STOP = 6; TONE_T = 7; LICKL = 8; LICKR = 9;
% for each animal, record whether it's a test or ctl  % 1 is ctl, 2 is test
condition=[0 0 2 0 2 0 0 0 2]; 
testIdx=find(condition==2);
lickIdx=[0 2 2 0 2];
cd(datapath(1:16)); 
lickIdx=find(lickIdx==2);lickHistMat=extractCellArray(lickHistMat);
allDataTestsOnly(2:length(testIdx)+1,:)=optomeanMat(testIdx,:);
lickMatTestsOnly(2:length(lickIdx)+1,:)=lickHistMat(lickIdx,:);
allDataTestsOnly=dreaddsHeader(allDataTestsOnly);

for rr=2:4
    lickArray=lickMatTestsOnly{rr,19};
    lickArray(isinf(lickArray)) = 0;
    lickMatTestsOnly{rr,19}=lickArray;
end
nbsubj=lickIdx-1;
dreaddsList={}; expRangeList={};
for tt=1:length(nbsubj)
    [mgbDays, icDays, expRange, dreadds] = getExpDays(datapath, nbsubj(tt));
    dreaddsList{tt}=dreadds; % 1 is baseline, 3 is saline, 4 is ligand
    expRangeList{tt}=expRange;
end

for rr=1:length(dreaddsList) 
    dreadds=dreaddsList{rr};
    dreaddsDay=find(dreadds==4);
    allDataHit=allDataTestsOnly{rr+1,2};%70dB
    allDataFa=allDataTestsOnly{rr+1,3};
    dreaddsHit=allDataHit(dreaddsDay);
    dreaddsFa=allDataFa(dreaddsDay);
    allDataTestsOnly{rr+1,18}=dreaddsHit;
    allDataTestsOnly{rr+1,19}=dreaddsFa;

    allDataHit=allDataTestsOnly{rr+1,4};%60dB
    allDataFa=allDataTestsOnly{rr+1,5};
    dreaddsHit=allDataHit(dreaddsDay);
    dreaddsFa=allDataFa(dreaddsDay);
    allDataTestsOnly{rr+1,20}=dreaddsHit;
    allDataTestsOnly{rr+1,21}=dreaddsFa;

    allDataHit=allDataTestsOnly{rr+1,6};%50dB
    allDataFa=allDataTestsOnly{rr+1,7};
    dreaddsHit=allDataHit(dreaddsDay);
    dreaddsFa=allDataFa(dreaddsDay);
    allDataTestsOnly{rr+1,22}=dreaddsHit;
    allDataTestsOnly{rr+1,23}=dreaddsFa;

    allDataHit=allDataTestsOnly{rr+1,8};%40dB
    allDataFa=allDataTestsOnly{rr+1,9};
    dreaddsHit=allDataHit(dreaddsDay);
    dreaddsFa=allDataFa(dreaddsDay);
    allDataTestsOnly{rr+1,24}=dreaddsHit;
    allDataTestsOnly{rr+1,25}=dreaddsFa;
end

rates={};rates=allDataTestsOnly{:,1};
rates{1,2}='Rates variable';
rates(2:4,2)=allDataTestsOnly(2:4,27);

%% make plot to compare percentage correct when light is on vs. off
% Compute percent correct, by session
reinfcolor= [0.4,0.4,0.4];
dreaddscolor=[0.8660 0.3290 0];
close all
xVector = [1 2 1 2 1 2];
plotsingleAnimal=1;
if plotsingleAnimal==1
    for jj=2:size(allDataTestsOnly,1)
        eeFig=figure(jj);hold on;
        rhit70=allDataTestsOnly{jj,10}; %Vehicle
        rfa70=allDataTestsOnly{jj,11};
        rhit60 = allDataTestsOnly{jj,12};
        rfa60= allDataTestsOnly{jj,13};
        rhit50 = allDataTestsOnly{jj,14};
        rfa50= allDataTestsOnly{jj,15};
        rhit40 = allDataTestsOnly{jj,16};
        rfa40= allDataTestsOnly{jj,17};
        rpc70 = (rhit70+(1-rfa70))/2*100; 
        rpc60 = (rhit60+(1-rfa60))/2*100; 
        rpc50 = (rhit50+(1-rfa50))/2*100; 
        rpc40 = (rhit40+(1-rfa40))/2*100;

        dhit70=allDataTestsOnly{jj,18}; %Ligand
        dfa70=allDataTestsOnly{jj,19};
        dhit60 = allDataTestsOnly{jj,20};
        dfa60= allDataTestsOnly{jj,21};
        dhit50 = allDataTestsOnly{jj,22};
        dfa50= allDataTestsOnly{jj,23};
        dhit40 = allDataTestsOnly{jj,24};
        dfa40= allDataTestsOnly{jj,25};
        dpc70 = (dhit70+(1-dfa70))/2*100; 
        dpc60 = (dhit60+(1-dfa60))/2*100; 
        dpc50 = (dhit50+(1-dfa50))/2*100; 
        dpc40 = (dhit40+(1-dfa40))/2*100;

        allRpc=[rpc70,rpc60,rpc50,rpc40];
        allDpc=[dpc70,dpc60,dpc50,dpc40];
        
        plotPsychCurve(allRpc,allDpc);
        eeFig.Position(3:4)=[725 475];
        saveas(gcf,[char(allDataTestsOnly{jj,1}) '_T_dreadds_psychPercentCorr']);
        saveas(gcf,[char(allDataTestsOnly{jj,1}) '_T_dreadds_psychPercentCorr.png']);    
    close all
end
else
end
close all
%% make plots to compare hit and fa rate with light on vs light off
close all
plotsingleAnimal=1;
if plotsingleAnimal==1
    for jj=2:size(allDataTestsOnly,1)
        eeFig=figure(jj+3);hold on;
        rhit=allDataTestsOnly{jj,10}; % full trial MGB
        rfa=allDataTestsOnly{jj,11};
        ohit = allDataTestsOnly{jj,12};
        ofa = allDataTestsOnly{jj,13};
        rhit(isnan(ohit))=nan;
        rfa(isnan(ofa))=nan;
        subplot(2,3,1)
        eee=bar([nanmean(rhit) nanmean(rfa) nanmean(ohit) nanmean(ofa)]); hold on;
        eee(1).FaceColor='flat'; eee(1).CData=[reinfcolor;reinfcolor;dreaddscolor;dreaddscolor];
        scatter(repmat(eee(1).XEndPoints(1),size(rhit,1),1), ...
            rhit,'MarkerEdgeColor',[0 0 0],'MarkerFaceColor',reinfcolor);
        scatter(repmat(eee(1).XEndPoints(2),size(rfa,1),2), ...
            rfa,'MarkerEdgeColor',[0 0 0],'MarkerFaceColor',reinfcolor);
        scatter(repmat(eee(1).XEndPoints(3),size(ohit,1),1), ...
            ohit,'MarkerEdgeColor',[0 0 0],'MarkerFaceColor',dreaddscolor);
        scatter(repmat(eee(1).XEndPoints(4),size(ofa,1),2), ...
            ofa,'MarkerEdgeColor',[0 0 0],'MarkerFaceColor',dreaddscolor);
        line([1 2],[rhit rfa], 'LineWidth', 0.5, 'Color', [0 0 0]);
        line([3 4],[ohit ofa],'LineWidth', 0.5, 'Color', [0 0 0]);
        [h,pHit,ci,stats] = ttest2(rhit,ohit);
        [h,pFA,ci,stats] = ttest2(rfa,ofa);
        sigstar({[1,3],[2,4]}, [pHit pFA])
        ylabel('rate');
        title([allDataTestsOnly{jj,1} ' MGB Full Trial Inactivation']);
        xticklabels({'hit','fa','hit','fa'});

        rhit=allDataTestsOnly{jj,10}; % tone MGB
        rfa=allDataTestsOnly{jj,11};
        ohit = allDataTestsOnly{jj,14};
        ofa = allDataTestsOnly{jj,15};
        rhit(isnan(ohit))=nan;
        rfa(isnan(ofa))=nan;
